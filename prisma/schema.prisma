generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  MENTOR
  ADMIN
}

enum CallType {
  RESUME_REVAMP
  JOB_MARKET_GUIDANCE
  MOCK_INTERVIEW
}

enum CallStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  password           String
  role               Role     @default(USER)
  timezone           String   @default("UTC")

  // Shared metadata (managed by Admin for mentors; self-reported for users)
  tags               String[] @default([])
  domain             String?
  description        String?

  // Mentor-specific metadata
  companyType        String?  @map("company_type")   // "big_tech" | "startup" | "mid_size"
  communicationScore Float?   @default(0) @map("communication_score")

  createdAt          DateTime @default(now()) @map("created_at")

  availabilityAsUser   Availability[] @relation("UserAvailability")
  availabilityAsMentor Availability[] @relation("MentorAvailability")
  meetingsAsAdmin      Meeting[]      @relation("AdminMeetings")
  callsAsUser          Call[]         @relation("UserCalls")
  callsAsMentor        Call[]         @relation("MentorCalls")
  callsAsAdmin         Call[]         @relation("AdminCalls")
}

model Availability {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  mentorId  String?  @map("mentor_id")
  role      Role
  date      DateTime @db.Date
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  isBooked  Boolean  @default(false) @map("is_booked")
  bookedAt  DateTime? @map("booked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user   User? @relation("UserAvailability",   fields: [userId],   references: [id], onDelete: Cascade)
  mentor User? @relation("MentorAvailability", fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([userId,   date, startTime], map: "availabilities_user_id_date_start_time_key")
  @@unique([mentorId, date, startTime], map: "availabilities_mentor_id_date_start_time_key")
  @@index([userId],       map: "availabilities_user_id_idx")
  @@index([mentorId],     map: "availabilities_mentor_id_idx")
  @@index([role],         map: "availabilities_role_idx")
  @@index([date],         map: "availabilities_date_idx")
  @@index([userId, date], map: "availabilities_user_id_date_idx")
  @@index([mentorId, date], map: "availabilities_mentor_id_date_idx")
  @@map("availabilities")
}

model Call {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  mentorId   String     @map("mentor_id")
  adminId    String     @map("admin_id")
  callType   CallType   @map("call_type")
  startTime  DateTime   @map("start_time")
  endTime    DateTime   @map("end_time")
  status     CallStatus @default(SCHEDULED)
  title      String?    @default("Mentoring Call")
  meetLink   String?    @map("meet_link")
  notes      String?
  createdAt  DateTime   @default(now()) @map("created_at")

  user   User @relation("UserCalls",   fields: [userId],   references: [id], onDelete: Cascade)
  mentor User @relation("MentorCalls", fields: [mentorId], references: [id], onDelete: Cascade)
  admin  User @relation("AdminCalls",  fields: [adminId],  references: [id], onDelete: Cascade)

  @@index([userId],   map: "calls_user_id_idx")
  @@index([mentorId], map: "calls_mentor_id_idx")
  @@index([adminId],  map: "calls_admin_id_idx")
  @@index([status],   map: "calls_status_idx")
  @@map("calls")
}

model Meeting {
  id              String   @id @default(uuid())
  adminId         String   @map("admin_id")
  title           String
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  meetLink        String?  @map("meet_link")
  calendarEventId String?  @map("calendar_event_id")
  googleEventId   String?  @map("google_event_id")
  createdAt       DateTime @default(now()) @map("created_at")

  admin        User                 @relation("AdminMeetings", fields: [adminId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        String @id @default(uuid())
  meetingId String @map("meeting_id")
  email     String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, email])
  @@map("meeting_participants")
}
