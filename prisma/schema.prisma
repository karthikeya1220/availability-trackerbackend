generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL moved to prisma.config.ts for Prisma 7+ per https://pris.ly/d/config-datasource
}

enum Role {
  USER
  MENTOR
  ADMIN
}

enum EntityType {
  user
  mentor
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  password           String
  role               Role     @default(USER)
  timezone           String   @default("UTC")
  createdAt          DateTime @default(now()) @map("created_at")

  availabilities Availability[]
  callsAsAdmin   Call[]         @relation("AdminCalls")
}

model Availability {
  id          String     @id @default(uuid())
  entityId    String     @map("entity_id")
  entityType  EntityType @map("entity_type")
  role        Role
  date        DateTime   @db.Date
  startTime   DateTime   @map("start_time")
  endTime     DateTime   @map("end_time")
  isBooked    Boolean    @default(false) @map("is_booked")
  bookedAt    DateTime?  @map("booked_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, entityType, date, startTime], map: "availabilities_entity_id_type_date_start_time_key")
  @@index([entityId], map: "availabilities_entity_id_idx")
  @@index([entityType], map: "availabilities_entity_type_idx")
  @@index([role], map: "availabilities_role_idx")
  @@index([date], map: "availabilities_date_idx")
  @@index([entityId, entityType], map: "availabilities_entity_id_type_idx")
  @@index([entityId, date], map: "availabilities_entity_id_date_idx")
  @@index([entityType, date], map: "availabilities_entity_type_date_idx")
  @@index([role, date], map: "availabilities_role_date_idx")
  @@map("availabilities")
}

model Call {
  id              String   @id @default(uuid())
  adminId         String   @map("admin_id")
  title           String
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  createdAt       DateTime @default(now()) @map("created_at")

  admin        User            @relation("AdminCalls", fields: [adminId], references: [id], onDelete: Cascade)
  participants CallParticipant[]

  @@map("calls")
}

model CallParticipant {
  id        String @id @default(uuid())
  callId    String @map("call_id")
  email     String

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@unique([callId, email])
  @@map("call_participants")
}
