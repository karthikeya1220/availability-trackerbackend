generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MENTOR
  ADMIN
}

enum EntityType {
  user
  mentor
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  password           String
  role               Role     @default(USER)
  timezone           String   @default("UTC")
  createdAt          DateTime @default(now()) @map("created_at")

  availabilities        Availability[]
  callsAsAdmin          Call[]              @relation("AdminCalls")
  callParticipantsAsUser   CallParticipant[] @relation("ParticipantAsUser")
  callParticipantsAsMentor CallParticipant[] @relation("ParticipantAsMentor")
  mentorProfile         MentorProfile?      @relation("MentorProfile")
  userProfile           UserProfile?        @relation("UserProfile")
}

model Availability {
  id          String     @id @default(uuid())
  entityId    String     @map("entity_id")
  entityType  EntityType @map("entity_type")
  role        Role
  date        DateTime   @db.Date
  startTime   DateTime   @map("start_time")
  endTime     DateTime   @map("end_time")
  isBooked    Boolean    @default(false) @map("is_booked")
  bookedAt    DateTime?  @map("booked_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, entityType, date, startTime], map: "availabilities_entity_id_type_date_start_time_key")
  @@index([entityId], map: "availabilities_entity_id_idx")
  @@index([entityType], map: "availabilities_entity_type_idx")
  @@index([role], map: "availabilities_role_idx")
  @@index([date], map: "availabilities_date_idx")
  @@index([entityId, entityType], map: "availabilities_entity_id_type_idx")
  @@index([entityId, date], map: "availabilities_entity_id_date_idx")
  @@index([entityType, date], map: "availabilities_entity_type_date_idx")
  @@index([role, date], map: "availabilities_role_date_idx")
  @@map("availabilities")
}

model Call {
  id              String   @id @default(uuid())
  adminId         String   @map("admin_id")
  title           String
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  createdAt       DateTime @default(now()) @map("created_at")

  admin        User            @relation("AdminCalls", fields: [adminId], references: [id], onDelete: Cascade)
  participants CallParticipant[]

  @@map("calls")
}

model CallParticipant {
  id        String  @id @default(uuid())
  callId    String  @map("call_id")
  userId    String? @map("user_id")
  mentorId  String? @map("mentor_id")
  
  // Keep email for backward compatibility during migration
  email     String?

  call   Call   @relation(fields: [callId], references: [id], onDelete: Cascade)
  user   User?  @relation("ParticipantAsUser", fields: [userId], references: [id], onDelete: SetNull)
  mentor User?  @relation("ParticipantAsMentor", fields: [mentorId], references: [id], onDelete: SetNull)

  // At least one of userId or mentorId must be set
  // Ensure userId and mentorId are unique per call (can't have same person twice)
  @@unique([callId, userId], map: "call_participants_call_user_idx")
  @@unique([callId, mentorId], map: "call_participants_call_mentor_idx")
  @@index([userId], map: "call_participants_user_id_idx")
  @@index([mentorId], map: "call_participants_mentor_id_idx")
  @@map("call_participants")
}

model MentorProfile {
  id                String   @id @default(uuid())
  mentorId          String   @unique @map("mentor_id")
  expertise         String[] @default([]) // Array of skill tags
  description       String   @default("") // Detailed bio/description
  company           String   @default("") // Company name
  companySize       String   @default("") @map("company_size") // e.g., "50000+", "100-500"
  communicationScore Float   @default(3.0) @map("communication_score") // 1-5 scale
  rating            Float    @default(4.0) // 1-5 star rating
  yearsOfExperience Int     @default(0) @map("years_of_experience")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  mentor User @relation("MentorProfile", fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([mentorId], map: "mentor_profile_mentor_id_idx")
  @@index([communicationScore], map: "mentor_profile_communication_score_idx")
  @@index([rating], map: "mentor_profile_rating_idx")
  @@map("mentor_profiles")
}

model UserProfile {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  interests     String[] @default([]) // Array of interest tags
  goal          String   @default("") // Primary learning goal
  domain        String   @default("") // Domain/specialty area
  description   String   @default("") // About user/background
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation("UserProfile", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_profile_user_id_idx")
  @@index([domain], map: "user_profile_domain_idx")
  @@map("user_profiles")
}
